{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug a4",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/a4",
            "args": ["-input","scene01_plane.txt","-size","200","200","-output","output01.bmp","-depth","8","12","depth01.bmp"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-debug",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
